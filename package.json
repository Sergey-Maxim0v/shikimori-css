{
  "homepage": "https://sergey-maxim0v.github.io/shikimori-css/",
  "private": true,
  "name": "shikimori-css",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:sass": "sass src/scss/main.scss dist/main.css --no-source-map",
    "prefix": "postcss dist/main.css --use autoprefixer --output dist/main.css",
    "minify": "postcss dist/main.css --use cssnano --output dist/main.min.css",
    "build": "npm-run-all build:sass prefix minify"
  },
  "keywords": [
    "shikimori",
    "css"
  ],
  "author": "Sergey-Maxim0v",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "sass": "^1.98.0"
  }
}
